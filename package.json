{
  "name": "@jbl/monorepo",
  "private": true,
  "type": "module",
  "license": "ISC",
  "workspaces": [
    "app",
    "packages/*"
  ],
  "scripts": {
    "wasm": "wasm-pack build crates/jbl-math-wasm --target bundler --out-dir $PWD/packages/wasm-lib && npm pkg set name='@jbl/wasm-lib' --prefix packages/wasm-lib",
    "dev": "bun run --filter @jbl/app dev",
    "build": "bun run --filter @jbl/app build",
    "preview": "bun run --filter @jbl/app preview",
    "test": "bun run --filter @jbl/test test",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "devDependencies": {
    "prettier": "^2.6.2"
  }
}